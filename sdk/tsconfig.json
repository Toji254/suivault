{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "declaration": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "types.ts",
    "parser.ts",
    "client.ts",
    "guardian.ts",
    "walrus.ts",
    "deepbook.ts",
    "market-scout.ts",
    "agent-state.ts",
    "probe-pool.ts",
    "index.ts"
  ]
}
